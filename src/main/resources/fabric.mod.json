{
	"schemaVersion": 1,
	"id": "craftable",
	"version": "${version}",
	"name": "Craftable",
	"description": "All the crafting recipes Mojang forgot to add, finally in one place!",
	"authors": [
		"Epsi_T"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/Epsi1223/Fabric-Craftable-26.X"
	},
	"license": "MIT_License",
	"icon": "assets/craftable/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.epsi.craftable.Craftable"
		],
		"fabric-datagen": [
			"net.epsi.craftable.CraftableDataGenerator"
		]
	},
	"mixins": [
		"craftable.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": ">=26 <27",
		"java": ">=25",
		"fabric-api": "*"
	}
}